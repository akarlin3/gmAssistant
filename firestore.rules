rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /worlds/{worldId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && (resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    function isValidCampaignUpdate() {
      return request.resource.data.updatedAt != null;
    }

    // Scene Mode (data.sceneSessions[*]) lives inside the campaign doc, which is
    // already owner-write-gated by the `update` rule below — only the campaign's
    // own user can write any of its `data`. Referential integrity of a scene's
    // `presentNpcIds` against `data.npcs` is enforced at the client (the picker
    // only offers real NPCs) and at the server (/api/scene/turn rejects dialogue
    // for NPC ids not present in the scene). Firestore rules can't iterate a
    // variable-length array of maps to subset-check ids against another array,
    // so that validation deliberately is not attempted here.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid ||
            (request.auth.uid in resource.data.get('playerIds', [])));

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
        && isValidCampaignUpdate()
        && (
          (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && (request.resource.data.get('worldId', null) == resource.data.get('worldId', null) || resource.data.get('worldId', null) == null))
          ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingPlayers', 'updatedAt']))
        );

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Subscription state — written server-side only (Firebase Admin SDK from Stripe webhook).
    // Clients read their own doc to react to status changes in real time.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // customer-id -> uid lookup, used by the webhook to resolve which user a Stripe customer maps to.
    // Server-only, never readable by clients.
    match /stripeCustomers/{customerId} {
      allow read, write: if false;
    }

    // Player Mode share docs. The GM (campaign owner) publishes redacted
    // projections here from their authenticated browser; unauthenticated
    // players read them via the share link. The unguessable shareToken in the
    // path is the capability — there are no player accounts (see
    // docs/player-mode-audit.md §5). Players never read source campaign docs.
    function ownsCampaign(campaignId) {
      return request.auth != null
        && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
    }
    function tokenMatchesCampaign(campaignId, shareToken) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.data.player.shareToken == shareToken;
    }
    match /playerShares/{shareToken} {
      // Require share token to be at least 20 characters (unguessable capability token).
      allow read: if shareToken.size() >= 20;
      // Only the owning GM may publish.
      allow create, update: if request.resource.data.campaignId is string
        && ownsCampaign(request.resource.data.campaignId);
      allow delete: if resource.data.campaignId is string
        && ownsCampaign(resource.data.campaignId);

      match /slots/{slotId} {
        // Public read of the redacted per-slot payload.
        allow read: if true;
        // Writable only by the GM who owns the campaign this share points to.
        allow write: if ownsCampaign(
          get(/databases/$(database)/documents/playerShares/$(shareToken)).data.campaignId
        );
      }
    }

    // Pro waitlist signups — clients write their own doc directly from the
    // Firebase Web SDK (the deployment can't use the Admin SDK because
    // service-account key creation is blocked by org policy). The schema is
    // locked here and the doc is write-once.
    match /proWaitlist/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.keys().hasOnly(['uid', 'email', 'displayName', 'createdAtMs', 'createdAt']);
      allow update, delete: if false;
    }
  }
}