rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /worlds/{worldId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && (resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    function isValidCampaignUpdate() {
      return request.resource.data.updatedAt != null;
    }

    // Scene Mode (data.sceneSessions[*]) lives inside the campaign doc, which is
    // already owner-write-gated by the `update` rule below — only the campaign's
    // own user can write any of its `data`. Referential integrity of a scene's
    // `presentNpcIds` against `data.npcs` is enforced at the client (the picker
    // only offers real NPCs) and at the server (/api/scene/turn rejects dialogue
    // for NPC ids not present in the scene). Firestore rules can't iterate a
    // variable-length array of maps to subset-check ids against another array,
    // so that validation deliberately is not attempted here.
    function isValidPc(pc) {
      return pc.get('ownership', null) == null || (pc.ownership.get('ownerType', 'dm') in ['dm', 'player']);
    }

    function isValidPcsList(pcs) {
      return pcs == null || (
        (pcs.size() < 1 || isValidPc(pcs[0])) &&
        (pcs.size() < 2 || isValidPc(pcs[1])) &&
        (pcs.size() < 3 || isValidPc(pcs[2])) &&
        (pcs.size() < 4 || isValidPc(pcs[3])) &&
        (pcs.size() < 5 || isValidPc(pcs[4])) &&
        (pcs.size() < 6 || isValidPc(pcs[5])) &&
        (pcs.size() < 7 || isValidPc(pcs[6]))
      );
    }

    match /campaigns/{campaignId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid ||
            (request.auth.uid in resource.data.get('playerIds', [])));

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isValidPcsList(request.resource.data.get(['data', 'pcs'], null));

      allow update: if request.auth != null
        && isValidCampaignUpdate()
        && (
          (
            resource.data.userId == request.auth.uid 
            && request.resource.data.userId == request.auth.uid 
            && (request.resource.data.get('worldId', null) == resource.data.get('worldId', null) || resource.data.get('worldId', null) == null)
            && isValidPcsList(request.resource.data.get(['data', 'pcs'], null))
          )
          ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingPlayers', 'updatedAt']))
        );

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // pcWritebacks: staging area for player-initiated PC sheet edits.
      // The GM (campaign owner) reads, applies, and deletes these from their
      // browser via the writeback reconciler. Unauthenticated player clients
      // may set/merge their own slot's writeback when their share token grants
      // access to this campaign and the slot is registered (proven by the
      // existence of the per-slot projection doc).
      match /pcWritebacks/{playerSlotId} {
        allow read, delete: if ownsCampaign(campaignId);

        allow create, update: if ownsCampaign(campaignId)
          || isValidPlayerWriteback(campaignId, playerSlotId);
      }

      // CRDT update log: opaque binary Yjs updates appended by the campaign
      // owner from any device. Append-only (no in-place updates / deletes
      // except by the snapshot-GC path, which the same owner runs). Players
      // never read these — the only player-facing surface remains the
      // public-read playerShares projection docs.
      match /crdtUpdates/{updateId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid
          && request.resource.data.clientId is string
          && request.resource.data.clock is number
          && request.resource.data.update is bytes;
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
        allow update: if false;
      }

      // CRDT snapshots: compacted full-state binary writes for fast cold
      // start. The same owner that writes a new snapshot also GCs the
      // updates and older snapshots subsumed by it.
      match /crdtSnapshots/{snapshotId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid
          && request.resource.data.state is bytes
          && request.resource.data.stateVector is bytes
          && request.resource.data.throughClock is number;
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
        allow update: if false;
      }
    }

    // Subscription state — written server-side only (Firebase Admin SDK from Stripe webhook).
    // Clients read their own doc to react to status changes in real time.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // customer-id -> uid lookup, used by the webhook to resolve which user a Stripe customer maps to.
    // Server-only, never readable by clients.
    match /stripeCustomers/{customerId} {
      allow read, write: if false;
    }

    // Player Mode share docs. The GM (campaign owner) publishes redacted
    // projections here from their authenticated browser; unauthenticated
    // players read them via the share link. The unguessable shareToken in the
    // path is the capability — there are no player accounts (see
    // docs/player-mode-audit.md §5). Players never read source campaign docs.
    function ownsCampaign(campaignId) {
      return request.auth != null
        && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
    }
    function tokenMatchesCampaign(campaignId, shareToken) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.data.player.shareToken == shareToken;
    }

    // Player writeback validator. Unauthenticated player clients hold only a
    // high-entropy shareToken — they prove their right to stage a writeback by
    // (a) embedding that token in the doc, (b) the token's playerShares doc
    // pointing at this campaign, and (c) a per-slot projection doc existing
    // (which only the GM can publish), which proves the slot is in the roster.
    // The doc structure is locked and `updates` may only contain keys from the
    // player-editable allowlist (mirrors lib/player/allowlist.ts).
    function isValidPlayerWriteback(campaignId, playerSlotId) {
      return request.resource.data.shareToken is string
        && request.resource.data.shareToken.size() >= 20
        && request.resource.data.pcId is string
        && request.resource.data.slotId == playerSlotId
        && request.resource.data.updatedAt is number
        && request.resource.data.updates is map
        && request.resource.data.updates.keys().hasOnly([
          'hp.current', 'hp.temp', 'conditions', 'exhaustion',
          'deathSaves.successes', 'deathSaves.failures', 'notes',
          'goals', 'bonds', 'ideals', 'flaws'
        ])
        && get(/databases/$(database)/documents/playerShares/$(request.resource.data.shareToken)).data.campaignId == campaignId
        && exists(/databases/$(database)/documents/playerShares/$(request.resource.data.shareToken)/slots/$(playerSlotId));
    }
    match /playerShares/{shareToken} {
      // Require share token to be at least 20 characters (unguessable capability token).
      allow read: if shareToken.size() >= 20;
      // Only the owning GM may publish.
      allow create, update: if request.resource.data.campaignId is string
        && ownsCampaign(request.resource.data.campaignId);
      allow delete: if resource.data.campaignId is string
        && ownsCampaign(resource.data.campaignId);

      match /slots/{slotId} {
        // Public read of the redacted per-slot payload.
        allow read: if true;
        // Writable only by the GM who owns the campaign this share points to.
        allow write: if ownsCampaign(
          get(/databases/$(database)/documents/playerShares/$(shareToken)).data.campaignId
        );
      }
    }

    // Pro waitlist signups — clients write their own doc directly from the
    // Firebase Web SDK (the deployment can't use the Admin SDK because
    // service-account key creation is blocked by org policy). The schema is
    // locked here and the doc is write-once.
    match /proWaitlist/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.keys().hasOnly(['uid', 'email', 'displayName', 'createdAtMs', 'createdAt']);
      allow update, delete: if false;
    }

    // Public waitlist signups — unauthenticated creates are allowed from the landing page
    match /publicWaitlist/{email} {
      allow create: if request.resource.data.email == email
        && request.resource.data.email is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.keys().hasOnly(['email', 'createdAtMs', 'createdAt']);
      allow read, update, delete: if false;
    }
  }
}