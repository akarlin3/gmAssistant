{
  "name": "gamemaster-builder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000} -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:node && npm run test:vitest",
    "test:node": "node --import tsx --test lib/generators/__tests__/*.test.ts lib/__tests__/*.test.ts lib/world/__tests__/*.test.ts",
    "test:vitest": "vitest run",
    "test:e2e": "playwright test",
    "test:rules": "firebase emulators:exec --only firestore --project player-mode-rules-test \"vitest run lib/playerMode/__tests__/rules.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.10.0",
    "jose": "^5.10.0",
    "konva": "^10.3.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.11",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4",
    "stripe": "^22.1.1",
    "use-image": "^1.1.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "firebase-tools": "^15.18.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
