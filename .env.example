# ── Firebase Web SDK (public, NEXT_PUBLIC_*) ─────────────────────────────
# Safe to expose in the client bundle. Required for auth + Firestore.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── AI features (server-only) ────────────────────────────────────────────
# Powers every Pro/LLM route (vivify, generators, parse-character-sheet, …).
# Get a key at console.anthropic.com. Without it, those routes return 500.
ANTHROPIC_API_KEY=

# ── OpenAI & ElevenLabs APIs (server-only) ──────────────────────────────────
# OPENAI_API_KEY: Powers NPC voice synthesis (OpenAI TTS) and AI battle-map
# generation (/api/maps/generate). Uses OpenAI Image API (gpt-image-1).
# Without it, those routes return 500.
OPENAI_API_KEY=

# ELEVENLABS_API_KEY: ElevenLabs is the optional higher-quality upgrade path
# for the NPC Voice feature (Pro). When unset, ElevenLabs is grayed out in
# the voice picker and /api/voice/list reports it as unavailable.
ELEVENLABS_API_KEY=

# ── Stripe subscription (server-only, currently dormant) ─────────────────
# Only needed if you re-enable the paid checkout flow. The webhook
# (/api/stripe/webhook) is the sole writer of users/{uid} subscription state.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Firebase Admin SDK credential, used ONLY by the Stripe webhook to mirror
# subscription state into Firestore. A JSON service-account key, stringified.
# Note: verifyPro (the Pro security boundary) does NOT use this — it verifies
# ID tokens via the public JWKS, so the rest of the app runs without it.
FIREBASE_SERVICE_ACCOUNT_JSON=
